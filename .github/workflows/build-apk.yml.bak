name: Build APK (Full Auto)

on:
  push:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: 📥 Checkout
        uses: actions/checkout@v4

      - name: 🟢 Node
        uses: actions/setup-node@v4
        with:
          node-version: 16

      - name: ☕ Java
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      # ===== 彻底物理重置：解决版本找不到和模块缺失 =====
      - name: 🔧 Force Fix Dependencies
        run: |
          rm -f package-lock.json
          
          # 1. 彻底从 package.json 里删掉所有 @dcloudio 的包，防止旧版本号干扰
          node -e "
            const fs = require('fs');
            const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
            const fix = (obj) => {
              if (!obj) return;
              for (let key in obj) {
                if (key.startsWith('@dcloudio/')) delete obj[key];
              }
            };
            fix(pkg.dependencies);
            fix(pkg.devDependencies);
            fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2));
          "

          # 2. 强行安装 NPM 上存在的确定版本，并手动补齐那个该死的 i18n 和 shared 包
          # 我们使用 2.0.1-3091020231219001，这是一个绝对能拉下来的 Vue2 稳定版本
          REAL_V="2.0.1-3091020231219001"
          npm install --legacy-peer-deps \
            @dcloudio/uni-app@$REAL_V \
            @dcloudio/uni-app-plus@$REAL_V \
            @dcloudio/uni-cli-shared@$REAL_V \
            @dcloudio/uni-cli-i18n@$REAL_V \
            @dcloudio/uni-h5@$REAL_V \
            @dcloudio/uni-helper-json@latest \
            @dcloudio/vue-cli-plugin-uni@$REAL_V \
            @dcloudio/webpack-uni-mp-loader@$REAL_V \
            @dcloudio/webpack-uni-pages-loader@$REAL_V

      # ===== 安装项目剩余依赖 =====
      - name: 📦 Install Remaining
        run: npm install --legacy-peer-deps --no-audit

      # ===== 编译前端 H5 产物 =====
      - name: 🏗️ Build H5
        run: npm run build:h5

      # ===== Capacitor 流程 (带上 --legacy-peer-deps 保证万无一失) =====
      - name: ⚙️ Init Capacitor
        run: |
          npm install @capacitor/cli @capacitor/core @capacitor/android --legacy-peer-deps
          npx cap init demo com.demo.app --web-dir=dist/build/h5
          npx cap add android
          npx cap sync android

      # ===== 签名与打包 APK =====
      - name: 🔐 Generate keystore
        run: |
          keytool -genkeypair -v \
          -keystore android/app/release.keystore \
          -alias demo \
          -keyalg RSA -keysize 2048 -validity 10000 \
          -storepass 123456 \
          -keypass 123456 \
          -dname "CN=demo, OU=dev, O=dev, L=dev, S=dev, C=US"

      - name: ✍️ Configure signing
        run: |
          cat >> android/gradle.properties <<EOF
          MYAPP_UPLOAD_STORE_FILE=release.keystore
          MYAPP_UPLOAD_KEY_ALIAS=demo
          MYAPP_UPLOAD_STORE_PASSWORD=123456
          MYAPP_UPLOAD_KEY_PASSWORD=123456
          EOF

      - name: 🔧 Patch gradle
        run: |
          sed -i '/buildTypes {/a \
              signingConfigs {\n\
                  release {\n\
                      storeFile file(MYAPP_UPLOAD_STORE_FILE)\n\
                      storePassword MYAPP_UPLOAD_STORE_PASSWORD\n\
                      keyAlias MYAPP_UPLOAD_KEY_ALIAS\n\
                      keyPassword MYAPP_UPLOAD_KEY_PASSWORD\n\
                  }\n\
              }' android/app/build.gradle
          sed -i 's/buildTypes {/buildTypes {\n        release {\n            signingConfig signingConfigs.release\n        }/g' android/app/build.gradle

      - name: 📦 Build APK
        run: |
          cd android
          chmod +x gradlew
          ./gradlew assembleRelease

      - name: 📤 Upload APK
        uses: actions/upload-artifact@v4
        with:
          name: apk
          path: android/app/build/outputs/apk/release/app-release.apk

      - name: 🚀 Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v${{ github.run_number }}
          files: android/app/build/outputs/apk/release/app-release.apk
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
