page { background: #f0f2f5; color: #333; }

.container { padding: 30rpx 30rpx 60rpx; }

/* ===== 顶部信息 ===== */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  padding: 44rpx 36rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.35);
}
.fund-info .name {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.fund-info .code {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}
.price-info { text-align: right; }
.price-info .label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  display: block;
}
.price-info .price {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 4rpx;
}

/* ===== 表单卡片 ===== */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-top: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 36rpx;
}
.title-bar {
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

.form-item { margin-bottom: 32rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.picker-view {
  display: flex;
  align-items: center;
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  border: 2rpx solid #f0f0f0;
}
.picker-icon { font-size: 30rpx; margin-right: 16rpx; }
.picker-text { font-size: 30rpx; color: #1a1a2e; font-weight: 600; flex: 1; }
.placeholder { color: #ccc; font-size: 28rpx; flex: 1; }
.arrow { font-size: 36rpx; color: #ccc; }

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f8f9fc;
  border-radius: 20rpx;
  border: 2rpx solid #e8e8e8;
  overflow: hidden;
  transition: border-color 0.3s;
  min-height: 100rpx;
}
.input-wrapper.disabled { opacity: 0.7; }
.input-prefix {
  font-size: 30rpx;
  color: #666;
  padding: 0 28rpx;
  font-weight: 600;
}
.input {
  flex: 1;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a2e;
  padding: 28rpx 28rpx 28rpx 0;
  min-height: 100rpx;
  line-height: 100rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #b0b0b0;
  margin-top: 10rpx;
  display: block;
}

/* ===== 成本预览 ===== */
.total-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.35);
}
.total-left { display: flex; flex-direction: column; }
.total-label { font-size: 28rpx; color: rgba(255,255,255,0.9); font-weight: 600; }
.total-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); margin-top: 6rpx; }
.total-value { font-size: 52rpx; font-weight: 800; color: #fff; }

/* ===== 提交按钮 ===== */
.btn-wrapper { margin-top: 56rpx; padding-bottom: 40rpx; }
.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  border-radius: 50rpx;
  padding: 30rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(102,126,234,0.4);
  border: none;
}
.btn-hover { opacity: 0.85; transform: scale(0.98); }
