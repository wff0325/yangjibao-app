page { background: linear-gradient(180deg, #667eea 0%, #f0f2f5 40%); min-height: 100vh; }

.container { padding: 30rpx 30rpx 160rpx; }

/* ===== 顶部资产卡片 ===== */
.header-card {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}
.header-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.header-icon { font-size: 28rpx; }
.header-label { font-size: 24rpx; color: rgba(255,255,255,0.75); letter-spacing: 2rpx; }
.header-value {
  font-size: 72rpx;
  font-weight: 800;
  margin: 20rpx 0 24rpx;
  letter-spacing: 2rpx;
}
.header-value.up { color: #ff8a8a; }
.header-value.down { color: #6ee7a0; }
.header-pnl-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.pnl-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.pnl-tag.up { background: rgba(239,68,68,0.2); color: #ff8a8a; }
.pnl-tag.down { background: rgba(34,197,94,0.2); color: #6ee7a0; }
.pnl-arrow { font-size: 18rpx; }
.pnl-pct { font-size: 26rpx; font-weight: bold; }
.pnl-pct.up { color: #ff8a8a; }
.pnl-pct.down { color: #6ee7a0; }

/* ===== 标签切换栏 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 50rpx;
  padding: 8rpx;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}
.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  color: #999;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}
.tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(102,126,234,0.35);
}
.tab-icon { font-size: 28rpx; }

/* ===== 列表区域 ===== */
.list { margin-top: 24rpx; }

/* ===== 持仓卡片 ===== */
.fund-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}
.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.card-title-area { flex: 1; }
.fund-name { font-size: 32rpx; font-weight: 700; color: #1a1a2e; }
.fund-code { font-size: 22rpx; color: #b0b0b0; margin-top: 6rpx; letter-spacing: 1rpx; }

.card-pnl {
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.card-pnl .pnl-amount { font-size: 34rpx; font-weight: 800; }
.card-pnl .pnl-rate { font-size: 22rpx; font-weight: 600; margin-top: 4rpx; }
.card-pnl.up .pnl-amount,
.card-pnl.up .pnl-rate { color: #ef4444; }
.card-pnl.down .pnl-amount,
.card-pnl.down .pnl-rate { color: #22c55e; }

.card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #e8e8e8 50%, transparent 100%);
  margin: 24rpx 0;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8f9fc;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
}
.col {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.col .val { font-size: 28rpx; font-weight: 700; color: #333; }
.col .lbl { font-size: 20rpx; color: #aaa; margin-top: 8rpx; letter-spacing: 1rpx; }
.col .up { color: #ef4444; }
.col .down { color: #22c55e; }

.col-divider {
  width: 1rpx;
  height: 48rpx;
  background: #e8e8e8;
}

/* ===== 自选卡片 ===== */
.fav-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.fav-info { flex: 1; }
.fav-name { font-size: 32rpx; font-weight: 700; color: #1a1a2e; }
.fav-code { font-size: 22rpx; color: #b0b0b0; margin-top: 6rpx; }

.fav-actions { display: flex; gap: 16rpx; align-items: center; }
.fav-btn {
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.fav-btn.add {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(102,126,234,0.3);
}
.fav-btn.del {
  background: #fff;
  color: #ef4444;
  border: 1rpx solid #fecaca;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #666; font-weight: 600; }
.empty-hint { font-size: 24rpx; color: #aaa; margin-top: 12rpx; }
