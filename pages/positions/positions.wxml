<view class="container">
  <!-- 类型选择器 -->
  <view class="type-selector">
    <view class="type-item {{typeIndex==0?'active':''}}" bindtap="switchType" data-index="0">
      <text class="type-emoji">💎</text>
      <text>基金</text>
    </view>
    <view class="type-item {{typeIndex==1?'active':''}}" bindtap="switchType" data-index="1">
      <text class="type-emoji">🇨🇳</text>
      <text>A股</text>
    </view>
    <view class="type-item {{typeIndex==2?'active':''}}" bindtap="switchType" data-index="2">
      <text class="type-emoji">🇭🇰</text>
      <text>港股</text>
    </view>
    <view class="type-item {{typeIndex==3?'active':''}}" bindtap="switchType" data-index="3">
      <text class="type-emoji">🇺🇸</text>
      <text>美股</text>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="输入代码、名称或拼音搜索" bindinput="onInput" value="{{keyword}}" confirm-type="search" bindconfirm="onSearch" />
    </view>
    <view class="search-btn" bindtap="onSearch" hover-class="btn-hover">搜索</view>
  </view>

  <!-- 搜索结果 -->
  <view class="result" wx:if="{{result}}">
    <view class="result-card">
      <view class="result-top">
        <view class="result-left">
          <view class="result-name">{{result.detail.name}}</view>
          <view class="result-code-row">
            <text class="result-code">{{result.code}}</text>
            <view class="result-type-badge">{{typeText}}</view>
          </view>
        </view>
      </view>
      <view class="result-price-row">
        <text class="result-price">{{result.detail.nav}}</text>
        <view class="result-chg {{result.detail.nav_chg >= 0 ? 'up' : 'down'}}">
          <text>{{result.detail.nav_chg >= 0 ? '▲' : '▼'}} {{result.detail.nav_chg}}%</text>
        </view>
      </view>
    </view>
    <view class="result-actions">
      <view class="btn-fav {{isFav?'active':''}}" bindtap="onToggleFav" hover-class="btn-hover">
        <text class="star">{{isFav?'★':'☆'}}</text>
        <text>{{isFav?'已自选':'加自选'}}</text>
      </view>
      <view class="btn-add" bindtap="goAdd" hover-class="btn-hover">
        <text>+ 添加持仓</text>
      </view>
    </view>
  </view>

  <!-- 热门推荐 -->
  <view class="hot-section" wx:if="{{!result}}">
    <view class="hot-title">🔥 热门{{typeText}}</view>
    <view class="hot-list">
      <view class="hot-item" wx:for="{{hotList}}" wx:key="code" bindtap="searchHot" data-kw="{{item.code}}" hover-class="card-hover">
        <view class="hot-rank">{{index + 1}}</view>
        <view class="hot-info">
          <text class="hot-name">{{item.name}}</text>
          <text class="hot-code">{{item.code}}</text>
        </view>
        <text class="hot-arrow">›</text>
      </view>
    </view>
  </view>
</view>
