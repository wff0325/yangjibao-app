page { background: #f0f2f5; color: #333; }

.container { padding: 30rpx; }

/* ===== 类型选择器 ===== */
.type-selector { display: flex; gap: 14rpx; margin-bottom: 28rpx; }
.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #999;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.3s;
}
.type-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.35);
}
.type-emoji { font-size: 32rpx; }

/* ===== 搜索栏 ===== */
.search-bar { display: flex; align-items: center; gap: 16rpx; }
.search-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}
.search-icon { font-size: 30rpx; margin-right: 16rpx; }
.search-input { flex: 1; height: 88rpx; font-size: 28rpx; }
.search-btn {
  width: 140rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(102,126,234,0.35);
}
.btn-hover { opacity: 0.85; transform: scale(0.97); }

/* ===== 搜索结果 ===== */
.result-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx;
  margin-top: 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06);
}
.result-top { margin-bottom: 24rpx; }
.result-name { font-size: 40rpx; font-weight: 800; color: #1a1a2e; }
.result-code-row { display: flex; align-items: center; gap: 16rpx; margin-top: 10rpx; }
.result-code { font-size: 24rpx; color: #b0b0b0; letter-spacing: 1rpx; }
.result-type-badge {
  background: linear-gradient(135deg, #e8eeff 0%, #f0e8ff 100%);
  color: #667eea;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.result-price-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}
.result-price { font-size: 60rpx; font-weight: 800; color: #1a1a2e; }
.result-chg {
  font-size: 26rpx;
  font-weight: 700;
  padding: 10rpx 20rpx;
  border-radius: 16rpx;
}
.result-chg.up { background: #fff1f1; color: #ef4444; }
.result-chg.down { background: #f0fdf4; color: #22c55e; }

.result-actions { display: flex; gap: 20rpx; margin-top: 28rpx; }
.btn-fav, .btn-add {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 28rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 700;
}
.btn-fav {
  background: #f8f9fc;
  color: #666;
  border: 2rpx solid #e8e8e8;
}
.btn-fav.active {
  background: #fffbeb;
  color: #f59e0b;
  border-color: #fde68a;
}
.btn-fav .star { font-size: 32rpx; }
.btn-add {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(102,126,234,0.35);
}

/* ===== 热门推荐 ===== */
.hot-section { margin-top: 44rpx; }
.hot-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}
.hot-list { display: flex; flex-direction: column; gap: 16rpx; }
.hot-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-hover { transform: scale(0.98); background: #f8f9fc; }
.hot-rank {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-right: 24rpx;
}
.hot-info { flex: 1; }
.hot-name { font-size: 30rpx; font-weight: 700; color: #1a1a2e; display: block; }
.hot-code { font-size: 22rpx; color: #b0b0b0; margin-top: 6rpx; letter-spacing: 1rpx; }
.hot-arrow { font-size: 40rpx; color: #ccc; }
